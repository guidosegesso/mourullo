[{"nombre":"Bloques de telgopor para embalaje","descripcionCorta":"Piezas de proteccion para envios, electrodomesticos y productos fragiles.","descripcionExtendida":"Se pueden adaptar a distintos formatos de caja y nivel de absorcion segun el peso del producto a proteger. Son una opcion habitual para traslados de equipos delicados y lineas de embalaje que requieren un soporte liviano pero confiable.","categoria":"Embalaje","precio":"Consultar cotizacion","imagenes":["/producto-bloques.svg","/producto-medida.svg"],"variantes":["Medidas personalizadas","Alta densidad","Corte recto o moldeado"]},{"nombre":"Esquineros protectores de EPS","descripcionCorta":"Refuerzos para proteger puntas y bordes en traslado y almacenamiento.","descripcionExtendida":"Disenados para absorber impactos en los puntos mas sensibles del producto, los esquineros de EPS son utiles para muebles, tableros, artefactos y piezas fragiles. Se pueden fabricar en distintas densidades y espesores.","categoria":"Embalaje","precio":"$ 18.505,00","imagenes":["/producto-bloques.svg"],"variantes":["Para muebles","Para linea blanca","Densidad media","Densidad alta"]},{"nombre":"Insertos de telgopor para cajas","descripcionCorta":"Separadores e insertos internos para asegurar piezas dentro del embalaje.","descripcionExtendida":"Estos insertos se desarrollan para inmovilizar componentes durante el transporte, reducir vibraciones y aprovechar mejor el espacio interno de la caja. Son ideales para productos electronicos, repuestos y elementos de precision.","categoria":"Embalaje","precio":"$ 331.505,00","imagenes":["/producto-medida.svg","/producto-bloques.svg"],"variantes":["Por muestra","Por plano","Series cortas","Series continuas"]},{"nombre":"Cunas de proteccion para electrodomesticos","descripcionCorta":"Apoyos moldeados para mantener el producto fijo dentro de su caja.","descripcionExtendida":"Las cunas de proteccion permiten sostener el producto en puntos de apoyo definidos y reducir el movimiento durante carga, descarga y traslado. Se adaptan a electrodomesticos pequenos, equipos tecnicos y piezas industriales.","categoria":"Embalaje","precio":"$ 2.138.505,00","imagenes":["/producto-bloques.svg"],"variantes":["Con apoyo lateral","Con base y tapa","Formato simetrico","Formato tecnico"]},{"nombre":"Planchas EPS para aislacion","descripcionCorta":"Planchas livianas para aplicaciones en obra seca, techos y aislacion termica.","descripcionExtendida":"Disponibles en distintas densidades y espesores para responder a requerimientos tecnicos y de obra. Funcionan bien en sistemas constructivos que necesitan mejorar el rendimiento termico sin sumar demasiado peso.","categoria":"Aislacion","precio":"$ 818.505,00","imagenes":["/producto-planchas.svg"],"variantes":["20 mm","30 mm","50 mm","Densidad estandar o reforzada"]},{"nombre":"Paneles EPS para cubierta","descripcionCorta":"Solucion de aislacion para techos y cubiertas livianas.","descripcionExtendida":"Pensados para mejorar el comportamiento termico de cubiertas y reducir ganancia o perdida de temperatura en espacios interiores. Se pueden integrar a sistemas livianos y soluciones modulares de obra.","categoria":"Aislacion","precio":"$ 351.505,00","imagenes":["/producto-planchas.svg","/producto-medida.svg"],"variantes":["40 mm","60 mm","80 mm","Con corte especial"]},{"nombre":"Placas de telgopor para camara frigorifica","descripcionCorta":"Placas aislantes para recintos que requieren estabilidad termica.","descripcionExtendida":"Estas placas se usan como parte de soluciones de cerramiento y aislacion en espacios que deben sostener temperatura controlada. Su bajo peso facilita manipulacion, instalacion y reemplazo.","categoria":"Aislacion","precio":"Segun espesor","imagenes":["/producto-planchas.svg"],"variantes":["Alta densidad","Corte a medida","Espesores especiales"]},{"nombre":"Rellenos livianos de EPS para obra","descripcionCorta":"Volumen de relleno para alivianar estructuras y nivelaciones.","descripcionExtendida":"Utilizados para reducir carga sobre losas, generar pendientes o resolver nivelaciones sin recurrir a materiales mas pesados. Son una alternativa practica para sistemas constructivos donde el peso es un factor clave.","categoria":"Aislacion","precio":"Consultar cotizacion","imagenes":["/producto-planchas.svg","/producto-bloques.svg"],"variantes":["Bloques livianos","Corte en obra","Distintas densidades"]},{"nombre":"Piezas tecnicas a medida","descripcionCorta":"Desarrollo de componentes especiales para industrias, muestras o series cortas.","descripcionExtendida":"Ideal para soportes internos, separadores, insertos y protecciones con medidas o geometria especifica. El desarrollo parte de una muestra, plano o requerimiento funcional definido por el cliente.","categoria":"Personalizado","precio":"Segun proyecto","imagenes":["/producto-medida.svg"],"variantes":["Por plano","Por muestra","Series cortas","Series continuas"]},{"nombre":"Logos corporeos en telgopor","descripcionCorta":"Piezas de exhibicion, branding y eventos realizadas en EPS.","descripcionExtendida":"Los logos corporeos permiten materializar marcas, letras y formas en gran tamano con un material liviano y facil de montar. Son utiles para vidrieras, eventos, acciones promocionales y ambientaciones temporales.","categoria":"Personalizado","precio":"Segun diseno","imagenes":["/producto-medida.svg","/producto-planchas.svg"],"variantes":["Letras sueltas","Logos completos","Terminacion lisa","Corte especial"]},{"nombre":"Moldes de telgopor para prototipos","descripcionCorta":"Volumenes y formas especiales para ensayos, prototipos y presentaciones.","descripcionExtendida":"Se producen piezas de prueba para validar volumen, forma o encastre antes de pasar a una etapa industrial definitiva. Tambien son utiles para maquetas, escenografia y soluciones de exhibicion.","categoria":"Personalizado","precio":"Consultar segun complejidad","imagenes":["/producto-medida.svg"],"variantes":["Maquetas","Prototipos","Escenografia","Piezas especiales"]},{"nombre":"Separadores tecnicos para industria","descripcionCorta":"Elementos disenados para organizar, proteger o distanciar componentes.","descripcionExtendida":"Se usan para separar conjuntos de piezas, sostener productos durante procesos internos o facilitar almacenaje y traslado entre etapas productivas. Pueden resolverse en EPS de distintas densidades segun la exigencia del uso.","categoria":"Personalizado","precio":"Segun aplicacion","imagenes":["/producto-medida.svg","/producto-bloques.svg"],"variantes":["Alta precision","Corte simple","Con encastre","Con cavidades"]}]