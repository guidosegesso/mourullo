{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "/mourullo",
  "redirects": [
    {
      "source": "/mourullo/",
      "destination": "/mourullo",
      "basePath": false,
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^/mourullo/$"
    },
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [
      {
        "source": "/mourullo//_next/:path+",
        "destination": "/mourullo/_next/:path+",
        "regex": "^/mourullo//_next(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))(?:/)?$"
      }
    ],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/productos/categoria/[categorySlug]",
      "regex": "^/productos/categoria/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPcategorySlug": "nxtPcategorySlug"
      },
      "namedRegex": "^/productos/categoria/(?<nxtPcategorySlug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/productos/[categorySlug]/[productSlug]",
      "regex": "^/productos/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPcategorySlug": "nxtPcategorySlug",
        "nxtPproductSlug": "nxtPproductSlug"
      },
      "namedRegex": "^/productos/(?<nxtPcategorySlug>[^/]+?)/(?<nxtPproductSlug>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/contacto",
      "regex": "^/contacto(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contacto(?:/)?$"
    },
    {
      "page": "/favicon.ico",
      "regex": "^/favicon\\.ico(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/favicon\\.ico(?:/)?$"
    },
    {
      "page": "/productos",
      "regex": "^/productos(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/productos(?:/)?$"
    },
    {
      "page": "/quienes-somos",
      "regex": "^/quienes\\-somos(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/quienes\\-somos(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}